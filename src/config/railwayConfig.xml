<?xml version="1.0" encoding="UTF-8"?>
<mxEditor>
  <!-- Stylesheet - minimal, using native maxGraph shapes -->
  <mxStylesheet as="stylesheet">
    <mxStyle name="defaultVertex">
      <mxCellStyle as="shape" name="shape" value="rectangle" />
      <mxCellStyle as="fillColor" name="fillColor" value="#ffffff" />
      <mxCellStyle as="strokeColor" name="strokeColor" value="#000000" />
      <mxCellStyle as="strokeWidth" name="strokeWidth" value="1" />
      <mxCellStyle as="fontColor" name="fontColor" value="#000000" />
      <mxCellStyle as="fontSize" name="fontSize" value="12" />
    </mxStyle>

    <mxStyle name="defaultEdge">
      <mxCellStyle as="edgeStyle" name="edgeStyle" value="orthogonalEdgeStyle" />
      <mxCellStyle as="strokeColor" name="strokeColor" value="#000000" />
      <mxCellStyle as="strokeWidth" name="strokeWidth" value="2" />
      <mxCellStyle as="endArrow" name="endArrow" value="block" />
    </mxStyle>
  </mxStylesheet>

  <!-- Shapes Library - native maxGraph shapes -->
  <mxShapes as="shapes">
    <mxShape name="rectangle" label="Rectangle" />
    <mxShape name="ellipse" label="Ellipse / Circle" />
    <mxShape name="diamond" label="Diamond" />
    <mxShape name="cylinder" label="Cylinder" />
    <mxShape name="triangle" label="Triangle" />
  </mxShapes>
</mxEditor>
