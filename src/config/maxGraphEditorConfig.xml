<?xml version="1.0" encoding="UTF-8"?>
<mxEditor>
  <!-- Default Editor Configuration for Railway Drawer -->

  <!-- Key Handler Configuration -->
  <keyhandler as="keyHandler">
    <add as="Ctrl+S" action="save"/>
    <add as="Ctrl+Z" action="undo"/>
    <add as="Ctrl+Y" action="redo"/>
    <add as="Ctrl+Shift+Z" action="redo"/>
    <add as="Ctrl+A" action="selectAll"/>
    <add as="Ctrl+C" action="copy"/>
    <add as="Ctrl+X" action="cut"/>
    <add as="Ctrl+V" action="paste"/>
    <add as="Ctrl+D" action="duplicate"/>
    <add as="Ctrl+G" action="group"/>
    <add as="Ctrl+Shift+G" action="ungroup"/>
    <add as="Delete" action="delete"/>
    <add as="Backspace" action="delete"/>
    <add as="F2" action="edit"/>
    <add as="Escape" action="stopEditing"/>
    <add as="Enter" action="stopEditing"/>
  </keyhandler>

  <!-- Style Configuration -->
  <styles>
    <!-- Default vertex style -->
    <add name="vertex" style="rounded=1;strokeColor=#999999;fillColor=#f0f0f0;strokeWidth=1;fontSize=12;fontFamily=Arial"/>

    <!-- Flowchart shapes -->
    <add name="process" style="shape=rectangle;rounded=1;strokeColor=#666666;fillColor=#e3f2fd;strokeWidth=2"/>
    <add name="decision" style="shape=rhombus;strokeColor=#ff9800;fillColor=#fff3e0;strokeWidth=2"/>
    <add name="terminator" style="shape=rectangle;rounded=1;strokeColor=#4caf50;fillColor=#e8f5e9;strokeWidth=2"/>
    <add name="database" style="shape=ellipse;strokeColor=#9c27b0;fillColor=#f3e5f5;strokeWidth=2"/>

    <!-- UML shapes -->
    <add name="actor" style="shape=rectangle;verticalAlign=top;rounded=0;strokeColor=#1976d2;fillColor=#e3f2fd;strokeWidth=2"/>
    <add name="usecase" style="shape=ellipse;strokeColor=#1976d2;fillColor=#e3f2fd;strokeWidth=2"/>
    <add name="class" style="shape=rectangle;verticalAlign=top;strokeColor=#1976d2;fillColor=#e3f2fd;strokeWidth=2"/>

    <!-- Rail/Network shapes -->
    <add name="signal" style="shape=rectangle;rounded=1;strokeColor=#d32f2f;fillColor=#ffebee;strokeWidth=2"/>
    <add name="station" style="shape=rectangle;rounded=1;strokeColor=#0097a7;fillColor=#e0f2f1;strokeWidth=2"/>
    <add name="track" style="shape=line;strokeColor=#666666;strokeWidth=3"/>

    <!-- Edge/Connector styles -->
    <add name="edge" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1;fontSize=12"/>
    <add name="connector" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;endArrow=classic"/>
    <add name="bezier" style="edgeStyle=curved;rounded=1;html=1;strokeColor=#666666;strokeWidth=1;endArrow=classic"/>

    <!-- Group/Container -->
    <add name="group" style="group=1;fillColor=none;strokeColor=#999999;strokeWidth=2;dashed=1"/>
  </styles>

  <!-- Default style for edges -->
  <defaultEdgeStyle style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1;fontSize=12;fontFamily=Arial;endArrow=classic"/>

  <!-- Default style for vertices -->
  <defaultVertexStyle style="rounded=1;strokeColor=#999999;fillColor=#f0f0f0;strokeWidth=1;fontSize=12;fontFamily=Arial;verticalAlign=middle;align=center"/>

  <!-- Toolbar Configuration -->
  <toolbar>
    <!-- File Operations -->
    <add as="New" action="new" icon="new.png"/>
    <add as="Open" action="open" icon="open.png"/>
    <add as="Save" action="save" icon="save.png"/>
    <add as="SaveAs" action="saveAs" icon="saveas.png"/>
    <add as="" as="spacer"/>

    <!-- Editing Operations -->
    <add as="Undo" action="undo" icon="undo.png"/>
    <add as="Redo" action="redo" icon="redo.png"/>
    <add as="" as="spacer"/>

    <!-- Copy/Paste -->
    <add as="Cut" action="cut" icon="cut.png"/>
    <add as="Copy" action="copy" icon="copy.png"/>
    <add as="Paste" action="paste" icon="paste.png"/>
    <add as="" as="spacer"/>

    <!-- Selection -->
    <add as="SelectAll" action="selectAll" icon="selectall.png"/>
    <add as="ClearSelection" action="clearSelection" icon="clearselection.png"/>
    <add as="" as="spacer"/>

    <!-- Grouping -->
    <add as="Group" action="group" icon="group.png"/>
    <add as="Ungroup" action="ungroup" icon="ungroup.png"/>
    <add as="" as="spacer"/>

    <!-- Zoom -->
    <add as="ZoomIn" action="zoomIn" icon="zoomin.png"/>
    <add as="ZoomOut" action="zoomOut" icon="zoomout.png"/>
    <add as="ResetZoom" action="resetZoom" icon="resetzoom.png"/>
    <add as="FitWindow" action="fitWindow" icon="fitwindow.png"/>
    <add as="" as="spacer"/>

    <!-- View -->
    <add as="ShowGrid" action="toggleGrid" icon="grid.png"/>
    <add as="ShowGuides" action="toggleGuides" icon="guides.png"/>
    <add as="SnapToGrid" action="toggleSnapToGrid" icon="snap.png"/>
  </toolbar>

  <!-- Shape Palette Configuration -->
  <shapeConfig>
    <!-- General Shapes -->
    <set name="General">
      <shape name="Rectangle" style="shape=rectangle;rounded=0"/>
      <shape name="Rounded" style="shape=rectangle;rounded=1"/>
      <shape name="Circle" style="shape=ellipse"/>
      <shape name="Diamond" style="shape=rhombus"/>
      <shape name="Triangle" style="shape=triangle"/>
      <shape name="Hexagon" style="shape=hexagon"/>
    </set>

    <!-- Flowchart Shapes -->
    <set name="Flowchart">
      <shape name="Process" style="process"/>
      <shape name="Decision" style="decision"/>
      <shape name="Terminator" style="terminator"/>
      <shape name="Database" style="database"/>
      <shape name="Document" style="shape=document"/>
      <shape name="Data" style="shape=parallelogram"/>
    </set>

    <!-- UML Shapes -->
    <set name="UML">
      <shape name="Actor" style="actor"/>
      <shape name="UseCase" style="usecase"/>
      <shape name="Class" style="class"/>
      <shape name="Component" style="shape=rectangle"/>
      <shape name="Package" style="shape=rectangle"/>
      <shape name="State" style="shape=ellipse"/>
    </set>

    <!-- Railway/Network Shapes -->
    <set name="Railway">
      <shape name="Signal" style="signal"/>
      <shape name="Station" style="station"/>
      <shape name="Track" style="track"/>
      <shape name="Junction" style="shape=rectangle;rounded=1"/>
      <shape name="Platform" style="shape=rectangle;rounded=0"/>
    </set>

    <!-- Connectors -->
    <set name="Connectors">
      <shape name="Line" style="edge"/>
      <shape name="Bezier" style="bezier"/>
      <shape name="Connector" style="connector"/>
      <shape name="Orthogonal" style="edgeStyle=orthogonalEdgeStyle"/>
    </set>
  </shapeConfig>

  <!-- Format Panel Configuration -->
  <formatPanel>
    <item name="Text">
      <option name="fontSize" type="select" values="8,9,10,11,12,14,16,18,20,24,28,32"/>
      <option name="fontFamily" type="text"/>
      <option name="fontColor" type="color"/>
      <option name="fontStyle" type="checkbox" label="Bold"/>
    </item>

    <item name="Fill">
      <option name="fillColor" type="color"/>
      <option name="fillOpacity" type="range" min="0" max="100"/>
    </item>

    <item name="Stroke">
      <option name="strokeColor" type="color"/>
      <option name="strokeWidth" type="select" values="1,2,3,4,5"/>
      <option name="strokeDashed" type="checkbox" label="Dashed"/>
    </item>

    <item name="Arrange">
      <option name="align" type="buttons" values="left,center,right"/>
      <option name="verticalAlign" type="buttons" values="top,middle,bottom"/>
      <option name="distribute" type="buttons" values="horizontally,vertically"/>
    </item>
  </formatPanel>

  <!-- Grid and Snap Configuration -->
  <grid enabled="true" size="40"/>
  <snap enabled="true" size="10"/>

  <!-- Connection Configuration -->
  <connections enabled="true">
    <allowLoops value="false"/>
    <allowDuplicateEdges value="true"/>
    <resetEdgesOnMove value="true"/>
    <resetEdgesOnResize value="true"/>
  </connections>

  <!-- Edit Configuration -->
  <edit>
    <autoSizeCells value="false"/>
    <cellsMovable value="true"/>
    <cellsResizable value="true"/>
    <cellsDeletable value="true"/>
    <cellsCloneable value="true"/>
    <cellsEditable value="true"/>
    <edgeLabelMovable value="true"/>
    <vertexLabelMovable value="true"/>
  </edit>
</mxEditor>
